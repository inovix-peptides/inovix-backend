{
  "name": "medusa-2.0-boilerplate-backend",
  "version": "0.0.2",
  "description": "A Prebaked Medusa 2.0 backend",
  "author": "Rasmus Puls",
  "license": "MIT",
  "keywords": [
    "sqlite",
    "postgres",
    "typescript",
    "ecommerce",
    "headless",
    "medusa"
  ],
  "scripts": {
    "build": "medusa build && node src/scripts/postBuild.js",
    "seed": "medusa exec ./src/scripts/seed.ts",
    "ib": "init-backend",
    "start": "init-backend && cd .medusa/server && medusa start --verbose",
    "dev": "medusa develop",
    "email:dev": "email dev --dir=./src/modules/email-notifications/templates --port=3002",
    "test": "jest --passWithNoTests",
    "test:watch": "jest --watch",
    "test:coverage": "jest --coverage"
  },
  "dependencies": {
    "@dnd-kit/core": "^6.1.0",
    "@dnd-kit/sortable": "^8.0.0",
    "@dnd-kit/utilities": "^3.2.2",
    "@medusajs/admin-sdk": "2.12.1",
    "@medusajs/admin-shared": "2.12.1",
    "@medusajs/cache-redis": "2.12.1",
    "@medusajs/cli": "2.12.1",
    "@medusajs/dashboard": "2.12.1",
    "@medusajs/draft-order": "2.12.1",
    "@medusajs/framework": "2.12.1",
    "@medusajs/icons": "2.12.1",
    "@medusajs/medusa": "2.12.1",
    "@medusajs/notification-sendgrid": "2.12.1",
    "@medusajs/ui": "4.0.29",
    "@medusajs/workflow-engine-redis": "2.12.1",
    "@react-email/components": "^1.0.1",
    "@rokmohar/medusa-plugin-meilisearch": "1.3.5",
    "@sentry/node": "^10.49.0",
    "@tiptap/extension-image": "^3.22.4",
    "@tiptap/extension-link": "^3.22.4",
    "@tiptap/extension-placeholder": "^3.22.4",
    "@tiptap/pm": "^3.22.4",
    "@tiptap/react": "^3.22.4",
    "@tiptap/starter-kit": "^3.22.4",
    "medusajs-launch-utils": "0.0.18",
    "minio": "^8.0.6",
    "resend": "4.0.1",
    "ulid": "^2.4.0",
    "uuid": "9.0.1"
  },
  "devDependencies": {
    "@medusajs/test-utils": "2.12.1",
    "@react-email/preview-server": "^5.1.0",
    "@swc/core": "1.5.7",
    "@swc/jest": "^0.2.39",
    "@types/jest": "^29.5.14",
    "@types/node": "^20.19.25",
    "@types/react": "^18.3.27",
    "@types/react-dom": "^18.3.7",
    "@types/uuid": "^9.0.8",
    "jest": "^29.7.0",
    "prop-types": "^15.8.1",
    "react": "^18.3.1",
    "react-dom": "^18.3.1",
    "react-email": "^5.1.0",
    "ts-node": "^10.9.2",
    "typescript": "^5.9.3",
    "vite": "^5.4.21"
  },
  "packageManager": "pnpm@9.10.0",
  "engines": {
    "node": "22.x",
    "npm": "10.x"
  },
  "pnpm": {
    "patchedDependencies": {
      "@medusajs/dashboard@2.12.1": "patches/@medusajs__dashboard@2.12.1.patch"
    }
  }
}
